# FakeIPTV environment configuration
# Copy this to .env and fill in your values.
# Values here override config.yaml.

# --- Media paths ---
FAKEIPTV_SHOWS_PATH=/mnt/nas/Shows
FAKEIPTV_MOVIES_PATH=/mnt/nas/Movies

# --- Server ---
FAKEIPTV_HOST=0.0.0.0
FAKEIPTV_PORT=8080
FAKEIPTV_RPI_IP=192.168.1.100        # Your Raspberry Pi's LAN IP

# --- HLS segment temp directory ---
# /run is a tmpfs ramdisk on Raspberry Pi OS — avoids SD card writes
FAKEIPTV_TMP_DIR=/run/fakeiptv

# --- Subtitles ---
# Include embedded subtitle tracks (SRT/ASS) converted to WebVTT in the HLS stream.
# Set to false to disable (e.g. if files have PGS/bitmap subs that cause ffmpeg errors).
FAKEIPTV_SUBTITLES=true

# --- Catch-up ---
# Number of past days available for catch-up playback. Set to 0 to disable.
FAKEIPTV_CATCHUP_DAYS=7

# --- Metadata ---
FAKEIPTV_TMDB_API_KEY=               # Leave empty to use NFO files only
FAKEIPTV_CACHE_DIR=/var/cache/fakeiptv

# --- Optional: path to config.yaml ---
# FAKEIPTV_CONFIG=config.yaml
