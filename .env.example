# Copy this to .env and fill in your values.
# docker-compose reads .env automatically.

# ── Server ────────────────────────────────────────────────────────────────────
FAKEIPTV_HOST=0.0.0.0
FAKEIPTV_PORT=8080
# LAN IP of the machine running the container — used in stream/EPG URLs
FAKEIPTV_HOST_IP=192.168.1.100
FAKEIPTV_LOG_LEVEL=INFO

# ── Media paths ───────────────────────────────────────────────────────────────
# Paths inside the container. Set to match where the NAS is mounted.
# Default docker-compose.yml mounts the NFS share at /multimedia.
FAKEIPTV_SHOWS_PATH=/mnt/nas/Shows
FAKEIPTV_MOVIES_PATH=/mnt/nas/Movies

# ── Metadata ──────────────────────────────────────────────────────────────────
FAKEIPTV_TMDB_API_KEY=
FAKEIPTV_SONARR_URL=
FAKEIPTV_SONARR_API_KEY=
FAKEIPTV_RADARR_URL=
FAKEIPTV_RADARR_API_KEY=

# ── Features ──────────────────────────────────────────────────────────────────
FAKEIPTV_SUBTITLES=true
FAKEIPTV_CATCHUP_DAYS=7

# ── Pre-warm modes (choose at most one) ───────────────────────────────────────
# Adjacent: warm N channels above+below the watched channel. Recommended.
# Uses FAKEIPTV_PREWARM_TIMEOUT (seconds) before stopping unwatched channels.
FAKEIPTV_PREWARM_ADJACENT=1
FAKEIPTV_PREWARM_TIMEOUT=120
# Session: warm all channels, keep alive until X seconds after last watch.
#FAKEIPTV_PREWARM_SESSION=true
# All: warm all channels, each with individual idle timeout.
#FAKEIPTV_PREWARM=true

# ── File paths ───────────────────────────────────────────────────────────────
# HLS segment temp directory (inside container). For non-Docker: use /dev/shm/fakeiptv
FAKEIPTV_TMP_DIR=/tmp/fakeiptv
# SQLite cache directory (inside container)
FAKEIPTV_CACHE_DIR=/cache

# ── tmpfs size for HLS segments (bytes) ───────────────────────────────────────
# 1 GB = 1073741824  /  2 GB = 2147483648
# Rule of thumb: ~25 MB per active channel (15 x 2s segments x ~1 MB each)
FAKEIPTV_TMPFS_SIZE=1073741824

# ── Timezone ──────────────────────────────────────────────────────────────────
# Must match the host timezone so the schedule epoch and EPG times are correct.
# Find yours with: timedatectl | grep "Time zone"
TZ=UTC
